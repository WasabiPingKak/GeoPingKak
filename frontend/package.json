{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "cp .env.staging .env.development.local && next dev --turbopack",
        "build": "next build",
        "build:staging": "cp .env.staging .env.production.local && next build",
        "build:prod": "rm -f .env.production.local && next build",
        "start": "next start",
        "lint": "eslint .",
        "postbuild": "next-sitemap",
        "deploy:staging": "npm run build:staging && firebase hosting:channel:deploy staging --expires 30d",
        "deploy:prod": "echo 'Production deploy is handled by CI/CD. Push to main branch.' && exit 1"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.83.0",
        "@tanstack/react-query-devtools": "^5.83.0",
        "@vnedyalk0v/react19-simple-maps": "^2.0.2",
        "clsx": "^2.1.1",
        "next": "^16.0.7",
        "next-sitemap": "^4.2.3",
        "react": "^19.2.1",
        "react-dom": "^19.2.1",
        "react-icons": "^5.5.0",
        "react-markdown": "^10.1.0",
        "react-medium-image-zoom": "^5.3.0",
        "remark-gfm": "^4.0.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "autoprefixer": "^10.4.21",
        "baseline-browser-mapping": "^2.10.0",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.1",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.3",
        "typescript": "^5"
    }
}
